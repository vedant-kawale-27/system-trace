{
  "name": "system-trace",
  "version": "0.4.0",
  "private": true,
  "description": "Privacy-first, local-first, cross-platform screen-time tracker.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "test:e2e": "wdio run e2e/wdio.conf.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@wdio/cli": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "@wdio/tauri-plugin": "^1.0.0",
    "@wdio/tauri-service": "^1.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "expect-webdriverio": "^5.6.8",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.3"
  }
}
